{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.a-tarasoff/zenmoney-mcp",
  "description": "MCP server for ZenMoney personal finance app",
  "repository": {
    "url": "https://github.com/a-tarasoff/zenmoney-mcp",
    "source": "github"
  },
  "version": "0.3.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "zenmoney-mcp",
      "version": "0.3.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "ZenMoney API token from https://zerro.app/token",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "ZENMONEY_TOKEN"
        }
      ]
    }
  ]
}